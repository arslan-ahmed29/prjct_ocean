# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file and rename the copy to ".env"  (just remove the ".example")
#   2. Sign up free at https://openweathermap.org/api and grab your API key
#   3. Paste your key below where it says YOUR_KEY_HERE
#
# If you leave this blank, the app will still work using realistic sample data.
# ─────────────────────────────────────────────────────────────────────────────

VITE_OWM_API_KEY=YOUR_KEY_HERE
